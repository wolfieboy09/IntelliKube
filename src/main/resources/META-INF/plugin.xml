<idea-plugin>
    <id>dev.wolfieboy09.intellikube</id>
    <name>IntelliKube</name>
    <vendor>Wolfieboy09</vendor>
    <version>$version</version>

    <description><![CDATA[
        A way to make KubeJS plugins a lot easier
        Includes the following:
            - Icons for Kube files
        ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <resource-bundle>messages.MessageBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <fileIconProvider implementation="dev.wolfieboy09.icons.KubeIconProvider"/>
        <postStartupActivity implementation="dev.wolfieboy09.inspection.watcher.PluginFileWatcher"/>
        <localInspection
                language="JAVA"
                implementationClass="dev.wolfieboy09.inspection.PluginRegistrationInspection"
                groupName="IntelliKube"
                enabledByDefault="true"
                level="WARNING"
                shortName="ModHandlerNotRegistered" key="inspection.mod.handler.not.registered.display.name"
        />
    </extensions>

</idea-plugin>
